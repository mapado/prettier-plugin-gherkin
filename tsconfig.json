// prettier-ignore
{
  "include": ["src"],

  "compilerOptions": {
    /* TypeScript config (modern / ESM / Node). */

    /* Language and Environment */
    "target": "ES2022",                                   /* Baseline JS output. */
    "lib": ["ES2023"],                                    /* Global types available at runtime (no DOM). */

    /* Modules (ESM + Node resolution) */
    "module": "NodeNext",                                 /* Match Node's ESM/CJS behavior. */
    "moduleResolution": "NodeNext",                       /* Resolve imports like Node does (incl. `exports`). */
    "moduleDetection": "force",                           /* Treat files as modules consistently. */
    "verbatimModuleSyntax": true,                          /* Preserve import/export; requires `import { type X }` for types. */

    /* Project structure */
    "rootDir": "src",                                     /* Keep emitted structure stable. */
    "outDir": "dist",                                     /* Build output. */

    /* Emit (library-friendly) */
    "declaration": true,                                  /* Publish types. */
    "declarationMap": true,                               /* Better "go to definition" from d.ts. */
    "sourceMap": true,                                    /* Debuggable builds. */
    // "emitDeclarationOnly": true,                        /* If you switch to a bundler for JS emit. */
    // "noEmit": true,                                     /* Useful for pure typecheck in CI. */

    /* Types */
    "types": ["node"],                                    /* Node globals/types (Buffer, process, etc.). */

    /* Type checking */
    "strict": true,                                       /* Strong type safety. */
    // "exactOptionalPropertyTypes": true,                 /* Stricter optional properties semantics. */
    // "noUncheckedIndexedAccess": true,                   /* Safer index access (adds `undefined`). */
    // "useUnknownInCatchVariables": true,                 /* More precise catch variables. */

    /* Interop / ergonomics */
    "esModuleInterop": true,                               /* Smooth default imports from CJS deps. */
    "forceConsistentCasingInFileNames": true,              /* Avoid case-only import bugs across OSes. */

    /* Performance */
    "skipLibCheck": true                                   /* Speeds up builds by skipping .d.ts checking. */
  }
}
